# NetBox MCP Server Configuration
# Copy this file to .env and fill in your actual values

# NetBox Instance Configuration (REQUIRED)
NETBOX_URL=https://your-netbox-instance.com
NETBOX_TOKEN=your-api-token-here

# MCP Transport Configuration
# - stdio: default (Claude Desktop style, client spawns server)
# - streamable-http: run as a network service (recommended for Docker / remote usage)
NETBOX_MCP_TRANSPORT=stdio
NETBOX_MCP_HOST=127.0.0.1
NETBOX_MCP_PORT=8000
NETBOX_MCP_PATH=/mcp

# MCP Host Allowlist (for streamable-http transport with DNS rebinding protection)
# Comma-separated list of allowed Host header values (include port if not 80/443)
# Example for Docker: MCP_ALLOWED_HOSTS=netbox-mc-rw:8000,localhost:8000,127.0.0.1:8000
# If not set when host is 0.0.0.0, DNS rebinding protection will be disabled
# MCP_ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000

# Optional: Streamable HTTP behavior
# Recommended for scalable deployments: NETBOX_MCP_STATELESS_HTTP=true and NETBOX_MCP_JSON_RESPONSE=true
NETBOX_MCP_STATELESS_HTTP=false
NETBOX_MCP_JSON_RESPONSE=false

# Tool Profile Configuration (for smaller LLMs like Ollama/qwen2.5)
# Available profiles: minimal, essential, ipam, dcim, readonly, write, full
# - essential (default): ~25 basic tools - list, get, search
# - ipam: ~35 tools for IP management
# - dcim: ~50 tools for infrastructure management
# - full: all 142+ tools (only for large models 14B+)
NETBOX_TOOL_PROFILE=essential
NETBOX_ENABLE_TOOL_PROFILES=true

# Optional: Health server (separate port)
NETBOX_ENABLE_HEALTH_SERVER=true
NETBOX_HEALTH_CHECK_PORT=8080

# Optional: Security and Performance
NETBOX_DRY_RUN=false
NETBOX_TIMEOUT=30
NETBOX_VERIFY_SSL=true

# Optional: Logging
NETBOX_LOG_LEVEL=INFO
NETBOX_LOG_FORMAT=json
